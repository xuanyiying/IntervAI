{
  "name": "AI-powered resume optimization",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered resume optimization SaaS platform",
  "workspaces": [
    "packages/frontend",
    "packages/backend"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' concurrently -n backend,frontend -c blue,green \"pnpm --filter=@interview-ai/backend start:dev\" \"pnpm --filter=@interview-ai/frontend start:dev\"",
    "dev:backend": "NODE_OPTIONS='--max-old-space-size=2048' pnpm --filter=@interview-ai/backend start:dev",
    "dev:frontend": "NODE_OPTIONS='--max-old-space-size=2048' pnpm --filter=@interview-ai/frontend start:dev",
    "build:backend": "pnpm --filter=@interview-ai/backend build",
    "build:frontend": "pnpm --filter=@interview-ai/frontend build",
    "test": "turbo run test",
    "test:parallel": "pnpm run test --recursive --parallel",
    "lint": "turbo run lint",
    "lint:fix": "pnpm run lint --recursive --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.6.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.3.8",
      "underscore": ">=1.13.7",
      "minimatch": ">=10.2.0",
      "liquidjs": ">=10.25.0",
      "serialize-javascript": ">=7.0.0",
      "hono": ">=4.7.0",
      "@hono/node-server": ">=1.14.0",
      "file-type": ">=20.0.0",
      "multer": ">=2.0.0",
      "axios": ">=1.8.0",
      "rollup": ">=4.22.0",
      "basic-ftp": ">=5.0.0",
      "ajv": ">=6.12.4",
      "qs": ">=6.14.0",
      "lodash": ">=4.17.21",
      "jws": ">=4.0.0",
      "undici": ">=6.21.0",
      "tar-fs": ">=3.0.8",
      "glob": ">=11.0.0",
      "ws": ">=8.18.0",
      "tough-cookie": ">=5.0.0",
      "nodemailer": ">=6.10.0",
      "mjml": ">=4.15.0",
      "js-yaml": ">=4.1.0",
      "diff": ">=5.2.0",
      "tmp": ">=0.2.3",
      "webpack": ">=5.98.0",
      "@langchain/community": ">=0.3.0",
      "langchain": ">=0.3.0",
      "langsmith": ">=0.3.0",
      "@remix-run/router": ">=1.21.0",
      "expr-eval": ">=2.0.2"
    }
  }
}
