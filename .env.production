# Production Environment Configuration

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# Domain Configuration
DOMAIN=udefined.cc
FRONTEND_URL=https://udefined.cc

BACKUP_DIR=./backups
# ============================================
# Database Configuration
# ============================================
# Using service name 'postgres' for internal docker network access
POSTGRES_DB=interview_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_postgres_2025
DATABASE_URL="postgresql://postgres:secure_postgres_2025@postgres:5432/interview_ai?schema=public&sslmode=disable&connection_limit=20&pool_timeout=30"

# Database Connection Pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=10000

# ============================================
# Redis Configuration
# ============================================
# Using service name 'redis' for internal docker network access
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secure_redis_2025
REDIS_TLS_ENABLED=false
REDIS_DB=0

# Vector Database (ChromaDB)
# Using service name 'chromadb'
CHROMA_DB_URL=http://chromadb:8000

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=EHrwXrdWH9oaV+IJ/IXrtwIpM58HD8FKnaf70zAEJ2ZxkBV8QTNlBuHER2OntzxYK3KlJ33w4ZI1ZrTuao6kCg==
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Object Storage (MinIO)
# ============================================
OSS_TYPE=minio
OSS_BUCKET=resume-files
OSS_REGION=us-east-1
# Internal endpoint for backend (using service name)
OSS_ENDPOINT=http://minio-prod:9000
# Public endpoint for browser access (needs domain/IP)
OSS_PUBLIC_ENDPOINT=https://oss.udefined.cc
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=secure_minio_admin_2025
OSS_PATH_STYLE=true
# Note: STORAGE_PROVIDER is used in docker-compose.prod.yml
STORAGE_PROVIDER=minio



# ============================================
# Frontend Configuration
# ============================================
# Required by frontend service in docker-compose
VITE_API_BASE_URL=https://udefined.cc/api/v1

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_FREE_TIER=10
RATE_LIMIT_PRO_TIER=1000
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_ENABLED=true

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,docx,txt,md
FILE_UPLOAD_TIMEOUT=60000

# ============================================
# Security Configuration
# ============================================
# CORS
CORS_ORIGIN=https://udefined.cc,https://www.udefined.cc
CORS_CREDENTIALS=true

# HTTPS/TLS
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# SSL Certificate (Let's Encrypt)
LETSENCRYPT_EMAIL=admin@udefined.cc
LETSENCRYPT_STAGING=false

# Content Security Policy
CSP_ENABLED=true

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info

# ============================================
# OAuth Configuration
